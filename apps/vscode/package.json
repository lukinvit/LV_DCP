{
    "name": "lv-dcp",
    "displayName": "LV_DCP — Developer Context Platform",
    "description": "Local-first context packs and impact analysis for your codebase. Query your project in plain language; LV_DCP returns the 2–5 most relevant files via a ranked retrieval pipeline.",
    "version": "0.8.30",
    "publisher": "lv-dcp",
    "license": "Apache-2.0",
    "homepage": "https://github.com/lukinvit/LV_DCP#readme",
    "repository": {
        "type": "git",
        "url": "https://github.com/lukinvit/LV_DCP.git",
        "directory": "apps/vscode"
    },
    "bugs": {
        "url": "https://github.com/lukinvit/LV_DCP/issues"
    },
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Programming Languages",
        "Machine Learning",
        "Other"
    ],
    "keywords": [
        "context",
        "retrieval",
        "rag",
        "claude",
        "cursor",
        "codebase",
        "impact-analysis",
        "local-first",
        "ai",
        "graph"
    ],
    "galleryBanner": {
        "color": "#1e1e1e",
        "theme": "dark"
    },
    "qna": "https://github.com/lukinvit/LV_DCP/discussions",
    "activationEvents": [
        "workspaceContains:**/.context/cache.db"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "lvdcp.getPack",
                "title": "LV_DCP: Get Context Pack"
            },
            {
                "command": "lvdcp.showImpact",
                "title": "LV_DCP: Show Impact"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "lvdcp",
                    "title": "LV_DCP",
                    "icon": "$(symbol-structure)"
                }
            ]
        },
        "views": {
            "lvdcp": [
                {
                    "id": "lvdcp.packResults",
                    "name": "Context Pack"
                }
            ]
        },
        "configuration": {
            "title": "LV_DCP",
            "properties": {
                "lvdcp.cliPath": {
                    "type": "string",
                    "default": "ctx",
                    "description": "Path to the `ctx` executable. Defaults to `ctx` on PATH. Set to an absolute path (e.g. `/usr/local/bin/ctx`) or a wrapper script (e.g. `/Users/you/bin/ctx-uv`) if `ctx` is not on PATH — useful when running via `uv run python -m apps.cli`."
                },
                "lvdcp.defaultMode": {
                    "type": "string",
                    "enum": [
                        "navigate",
                        "edit"
                    ],
                    "enumDescriptions": [
                        "Navigation mode — ranks files for reading / understanding the code.",
                        "Edit mode — ranks files for modification, with impact-aware weighting."
                    ],
                    "default": "navigate",
                    "description": "Default retrieval mode for the `LV_DCP: Get Context Pack` command. The `LV_DCP: Show Impact` command always uses `edit` mode regardless of this setting."
                },
                "lvdcp.cliTimeoutMs": {
                    "type": "number",
                    "default": 30000,
                    "minimum": 1000,
                    "maximum": 300000,
                    "description": "Timeout (in milliseconds) for `ctx` subprocess calls. Increase if your project is large and pack generation routinely exceeds the default."
                }
            }
        }
    },
    "scripts": {
        "compile": "tsc -p ./",
        "vscode:prepublish": "npm run compile",
        "package": "npx @vscode/vsce package --no-dependencies",
        "publish": "npx @vscode/vsce publish --no-dependencies"
    },
    "devDependencies": {
        "@types/vscode": "^1.85.0",
        "@types/node": "^20.0.0",
        "typescript": "^5.4.0",
        "@vscode/vsce": "^2.22.0"
    }
}
