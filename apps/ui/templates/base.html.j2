<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}LV_DCP Dashboard{% endblock %}</title>
    <link rel="stylesheet" href="/static/css/base.css">
    <script src="/static/vendor/d3.v7.min.js"></script>
    <script src="https://unpkg.com/htmx.org@2.0.3"></script>
</head>
<body>
    <header class="topbar">
        <a class="brand" href="/">LV_DCP</a>
        <nav>
            <a href="/">Overview</a>
            <a href="/settings">Settings</a>
        </nav>
        {% include "partials/budget_widget.html.j2" %}
        {% block usage_widget %}{% endblock %}
    </header>
    <main>
        {% block content %}{% endblock %}
    </main>
    <footer>
        <span>LV_DCP Dashboard &bull; v0.6.1</span>
        <a href="#" onclick="window.location.reload(); return false;">refresh</a>
    </footer>
    <script src="/static/js/dashboard.js"></script>
</body>
</html>
