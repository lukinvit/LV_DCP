{% extends "base.html.j2" %}
{% block title %}{{ status.card.name }} &mdash; LV_DCP{% endblock %}

{% block usage_widget %}
    {% include "partials/usage_widget.html.j2" %}
{% endblock %}

{% block content %}
    <h1>{{ status.card.name }}</h1>
    <p class="subtitle"><code>{{ status.card.root }}</code></p>

    <section class="section">
        <h2>Health</h2>
        {% with card=status.card %}
            {% include "partials/health_card.html.j2" %}
        {% endwith %}
    </section>

    {% with coverage=status.scan_coverage %}
        {% include "partials/scan_coverage.html.j2" %}
    {% endwith %}

    {% with wr=status.wiki_refresh, slug=status.card.slug %}
        {% include "partials/wiki_refresh.html.j2" %}
    {% endwith %}

    <section class="section">
        <h2>Dependency graph</h2>
        {% include "partials/graph_panel.html.j2" %}
    </section>

    <section class="section">
        <h2>Sparklines (rolling 7d)</h2>
        {% include "partials/sparkline_row.html.j2" %}
    </section>

    {% include "partials/hotspots.html.j2" %}

    {% include "partials/summaries_list.html.j2" %}

    <section class="section">
        <h2>Obsidian Sync</h2>
        {% if obsidian_config.enabled and obsidian_config.vault_path %}
        <p>Vault: <code>{{ obsidian_config.vault_path }}</code></p>
        <button type="button"
                hx-post="/api/project/{{ status.card.slug }}/obsidian-sync"
                hx-target="#obsidian-sync-result"
                hx-swap="innerHTML">
            Sync to Obsidian
        </button>
        <span id="obsidian-sync-result"></span>
        {% else %}
        <p class="muted">Configure vault path in <code>~/.lvdcp/config.yaml</code> first:</p>
        <pre><code>obsidian:
  enabled: true
  vault_path: /path/to/your/vault</code></pre>
        {% endif %}
    </section>
{% endblock %}
