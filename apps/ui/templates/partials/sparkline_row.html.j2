<div class="sparkline-row" data-project-slug="{{ status.card.slug }}">
    <div class="sparkline-item" data-metric="queries">
        <span class="label">Queries</span>
        <svg class="sparkline" width="200" height="40"></svg>
    </div>
    <div class="sparkline-item" data-metric="scans">
        <span class="label">Scans</span>
        <svg class="sparkline" width="200" height="40"></svg>
    </div>
    <div class="sparkline-item" data-metric="latency_p95_ms">
        <span class="label">Latency p95 (ms)</span>
        <svg class="sparkline" width="200" height="40"></svg>
    </div>
    <div class="sparkline-item" data-metric="coverage">
        <span class="label">Coverage avg</span>
        <svg class="sparkline" width="200" height="40"></svg>
    </div>
</div>
