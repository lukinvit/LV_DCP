<dialog id="add-project-dialog" style="border:1px solid #ccc;border-radius:8px;padding:24px;max-width:500px;">
    <h3 style="margin-top:0;">Add Project</h3>
    <form method="post" action="/api/projects/add">
        <label for="project-path" style="display:block;margin-bottom:4px;font-size:14px;">
            Absolute path to project directory:
        </label>
        <input type="text" name="path" id="project-path"
               placeholder="/Users/you/projects/my-project"
               required
               style="width:100%;padding:8px;border:1px solid #ccc;border-radius:4px;font-size:14px;box-sizing:border-box;">
        <div style="margin-top:16px;display:flex;gap:8px;justify-content:flex-end;">
            <button type="button" onclick="this.closest('dialog').close()"
                    style="padding:8px 16px;border:1px solid #ccc;border-radius:4px;background:white;cursor:pointer;">
                Cancel
            </button>
            <button type="submit"
                    style="padding:8px 16px;border:none;border-radius:4px;background:#2a5caa;color:white;cursor:pointer;">
                Add &amp; Scan
            </button>
        </div>
    </form>
</dialog>
